DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Set this to any random string you choose. You will enter the SAME string
# in the Meta developer dashboard when you register the webhook URL.
WHATSAPP_VERIFY_TOKEN=change-me

# The real Meta API credential, from the API Setup page in your Meta app.
# Rotate immediately if this ever ends up somewhere it shouldn't (chat, a
# public repo, a screenshot).
WHATSAPP_ACCESS_TOKEN=change-me

# Identifier for your WhatsApp test number, also from the API Setup page.
# Not a secret, just an ID used in API URLs.
WHATSAPP_PHONE_NUMBER_ID=change-me

# Local dev default assumes Memurai (or real Redis) running on the standard
# port. No change needed unless your local setup differs.
REDIS_URL=redis://localhost:6379/0
